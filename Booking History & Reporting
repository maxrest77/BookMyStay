import java.util.*;

// ----- RESERVATION (ENHANCED WITH ID) -----
class Reservation {
    private String reservationId;
    private String guestName;
    private String roomType;

    public Reservation(String reservationId, String guestName, String roomType) {
        this.reservationId = reservationId;
        this.guestName = guestName;
        this.roomType = roomType;
    }

    public String getReservationId() {
        return reservationId;
    }

    public String getGuestName() {
        return guestName;
    }

    public String getRoomType() {
        return roomType;
    }

    public void display() {
        System.out.println("ID: " + reservationId +
                " | Guest: " + guestName +
                " | Room: " + roomType);
    }
}

// ----- BOOKING HISTORY (STATE STORAGE) -----
class BookingHistory {

    private List<Reservation> history;

    public BookingHistory() {
        history = new ArrayList<>();
    }

    // Add confirmed reservation
    public void addReservation(Reservation reservation) {
        history.add(reservation);
    }

    // Read-only access
    public List<Reservation> getAllReservations() {
        return Collections.unmodifiableList(history);
    }

    // Display all bookings
    public void displayHistory() {
        System.out.println("\n----- BOOKING HISTORY -----");
        for (Reservation r : history) {
            r.display();
        }
    }
}

// ----- REPORT SERVICE (READ-ONLY) -----
class BookingReportService {

    // Total bookings
    public void totalBookings(BookingHistory history) {
        int count = history.getAllReservations().size();
        System.out.println("\nTotal Bookings: " + count);
    }

    // Count per room type
    public void bookingsByRoomType(BookingHistory history) {
        Map<String, Integer> report = new HashMap<>();

        for (Reservation r : history.getAllReservations()) {
            report.put(r.getRoomType(),
                    report.getOrDefault(r.getRoomType(), 0) + 1);
        }

        System.out.println("\nBookings by Room Type:");
        for (Map.Entry<String, Integer> entry : report.entrySet()) {
            System.out.println(entry.getKey() + " -> " + entry.getValue());
        }
    }

    // Detailed report
    public void detailedReport(BookingHistory history) {
        System.out.println("\n----- DETAILED REPORT -----");
        for (Reservation r : history.getAllReservations()) {
            r.display();
        }
    }
}

// ----- MAIN APPLICATION -----
public class MainApp {

    public static void main(String[] args) {

        // Booking history storage
        BookingHistory bookingHistory = new BookingHistory();

        // Simulating confirmed bookings (from UC6)
        bookingHistory.addReservation(new Reservation("S1A2B", "Alice", "Single"));
        bookingHistory.addReservation(new Reservation("S9X3K", "Bob", "Single"));
        bookingHistory.addReservation(new Reservation("D4P8Q", "Charlie", "Double"));
        bookingHistory.addReservation(new Reservation("SU7L2M", "David", "Suite"));

        // Display history
        bookingHistory.displayHistory();

        // Reporting
        BookingReportService reportService = new BookingReportService();

        reportService.totalBookings(bookingHistory);
        reportService.bookingsByRoomType(bookingHistory);
        reportService.detailedReport(bookingHistory);

        System.out.println("\nReports generated. No data modified.");
    }
}
